# ============================================================================
#  DELIVERY   (Next.js)                              proceso pm2: procovar-delivery
# ----------------------------------------------------------------------------
#  En el VPS:  cp .env.vps.example .env   y rellena los CAMBIAR_*
#  Arranca con:  next start -p 3002   (puerto 3002)
#  NOTA: las NEXT_PUBLIC_* se hornean en el BUILD (npm run build); si las cambias,
#  recompila. Las demás se leen en runtime.
# ============================================================================

# --- Base de datos PostgreSQL (BD propia de delivery) ------------------------
DATABASE_URL=postgresql://procovar:CAMBIAR_PASSWORD_DB@localhost:5432/procovar_delivery?schema=public

# --- Seguridad ---------------------------------------------------------------
# JWT: DEBE SER EL MISMO que el de PEDIDO/api para compartir sesión. Si está vacío,
# delivery NO arranca.
JWT_SECRET=CAMBIAR_mismo_jwt_que_PEDIDO

# Clave servidor-a-servidor. MISMA que SERVICE_API_KEY en PEDIDO/api.
SERVICE_API_KEY=CAMBIAR_misma_clave_que_PEDIDO

# --- URLs públicas / de servicio ---------------------------------------------
# URL pública con la que el navegador abre delivery (dominio en prod).
NEXT_PUBLIC_APP_URL=https://delivery.tudominio.com
# URL propia del servicio (para los workers internos). En el mismo VPS: localhost.
DELIVERY_URL=http://localhost:3002
# Dónde está la API de PEDIDO (para el worker que jala pedidos).
PEDIDO_API_URL=http://localhost:8400

# --- Data Warehouse (API externa de pesos/cotización, solo por VPN WireGuard) -
WAREHOUSE_API_URL=http://10.188.2.2:3001/api/external-api
WAREHOUSE_API_TOKEN=CAMBIAR_token_permanente_warehouse

# --- Redis (eventos del SSE de sincronización) -------------------------------
# OPCIONAL: sin REDIS_URL, delivery funciona igual (el SSE /api/sync/stream sondea
# la tabla SyncJob cada 1.5s). Con REDIS_URL, el worker sync-queue.mjs publica en
# procovar-delivery:sync:changed y el SSE refresca por EVENTO (sin sondeo por cliente).
# Debe ser el MISMO Redis que PEDIDO (prefijos distintos evitan colisión).
# En docker: redis://redis:6379. Suelto/local: localhost.
REDIS_URL=redis://localhost:6379
# Sentinel (HA multi-nodo) — vacío para modo simple. Si se rellenan AMBOS, mandan.
#   REDIS_SENTINELS=host1:26379,host2:26379,host3:26379
#   REDIS_MASTER_NAME=procovar-master
REDIS_SENTINELS=
REDIS_MASTER_NAME=
# Cache del catálogo de pesos del warehouse (segundos). Con Redis, evita re-bajar por
# VPN el catálogo en cada lote de cotización. Sin Redis, no aplica (se baja directo).
WAREHOUSE_WEIGHTS_TTL=600

# --- Entorno -----------------------------------------------------------------
# Delivery trabaja con TODAS las sucursales (no se fija ninguna aquí: el código
# ya es multi-sucursal; si no se pasa filtro, procesa todas).
NODE_ENV=production
