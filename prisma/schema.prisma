generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         String        @default("admin")
  createdAt    DateTime      @default(now())
  orders       Order[]
  routes       Route[]
  vehicles     Vehicle[]
  savedOrigins SavedOrigin[]
  branchId     String?
  branch       Branch?       @relation("UserBranch", fields: [branchId], references: [id])
  createdBranches Branch[]    @relation("BranchCreator")
  products     Product[]
}

model Product {
  id              String   @id @default(cuid())
  name            String
  weight          Float    @default(0)
  packaging       String?
  unitsPerPackage Float?
  category        String?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Branch {
  id         String   @id @default(cuid())
  name       String
  address    String?
  lat        Float
  lng        Float
  areaKm2    Float    @default(1)
  // Id de la sucursal equivalente en la app PEDIDO. Permite que PEDIDO cotice
  // un domicilio mandando solo su id de sucursal y delivery resuelve las coords.
  externalId String?  @unique
  creatorId  String
  creator    User     @relation("BranchCreator", fields: [creatorId], references: [id])
  members    User[]   @relation("UserBranch")
  origins    SavedOrigin[]
  orders     Order[]
  createdAt  DateTime @default(now())
}

model SavedOrigin {
  id        String   @id @default(cuid())
  name      String
  address   String
  lat       Float
  lng       Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
}

model Vehicle {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("truck")
  plate     String?
  capacity  Float    @default(1000)
  status    String   @default("available")
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  routes    Route[]
  orders    Order[]
  orderAssignments OrderVehicle[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String    @id @default(cuid())
  operationNumber String?
  customerName    String
  address         String
  endAddress      String?
  endLat          Float?
  endLng          Float?
  lat             Float?
  lng             Float?
  weight          Float     @default(1)
  status          String    @default("pending")
  tripLeg         String    @default("outbound")
  notes           String?
  routeId         String?
  route           Route?    @relation(fields: [routeId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  price           Float?
  segmentKm       Float?
  // Precio del envío a domicilio INDIVIDUAL (viaje dedicado sucursal → cliente).
  // Fuente de verdad para lo que se le cobra al cliente y lo que registra la
  // contabilidad en PEDIDO. Independiente de `price` (precio de reparto de ruta);
  // el flujo de rutas no lo sobrescribe.
  deliveryPrice      Float?
  deliveryDistanceKm Float?
  // Sucursal de origen desde la que se calculó el domicilio.
  branchId        String?
  branch          Branch?   @relation(fields: [branchId], references: [id])
  // Procedencia: "pedido" si entró desde la app PEDIDO, null si es manual.
  source          String?
  // Id/folio del pedido en PEDIDO. Usado para idempotencia (re-cotizar no duplica).
  externalId      String?
  // Itemized breakdown of what to deliver to this client: [{ description, quantity }]
  items           Json      @default("[]")
  // Teléfono del cliente y payload COMPLETO tal como llega de PEDIDO (cliente + pedido),
  // para no perder ningún dato (municipio, tipo, encargado, folio, estado, etc.).
  customerPhone   String?
  meta            Json?
  vehicleAssignments OrderVehicle[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  stopOrder       Int?
  deliveredAt     DateTime?

  @@index([source, externalId])
}

model OrderVehicle {
  id        String   @id @default(cuid())
  orderId   String
  vehicleId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([orderId, vehicleId])
}

model Route {
  id              String   @id @default(cuid())
  name            String?
  routeCode       String?
  status          String   @default("planned")
  originAddress   String?
  originLat       Float?
  originLng       Float?
  totalDistance   Float    @default(0)
  totalWeight     Float    @default(0)
  totalPrice      Float    @default(0)
  deliveryDate    DateTime?
  orders          Order[]
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  optimized       Boolean  @default(false)
}

model Settings {
  id        String @id @default(cuid())
  baseFee   Float  @default(5.0)
  costPerKm Float  @default(1.5)
  costPerKg Float  @default(0.5)
  // Parámetros del envío a domicilio INDIVIDUAL (separados de los de ruta).
  // Default 0 → la fórmula se reduce a base + dist + peso hasta que se configuren.
  domBaseFee    Float @default(0)
  domCostPerKm  Float @default(0)
  domCostPerKg  Float @default(0)
  domIncludedKm Float @default(0)
  domMinFee     Float @default(0)
  domRoundTo    Float @default(0)
  currency  String @default("USD")
  cupRate   Float  @default(320.0)
  cupRateUpdatedAt DateTime @default(now())
  // Display currencies relative to USD (base = 1). Array of { code, rate } where
  // rate = units of this currency per 1 USD. e.g. [{"code":"CUP","rate":320}]
  currencies Json @default("[]")
}
